# FRED (미국 10년물 국채금리)
FRED_API_KEY=

# 네이버 데이터랩 / 오픈API (검색 트렌드, 종목토론방)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# KRX Open API (코스피 시세, 신고가 괴리율, 버핏지수 시총)
KRX_API_KEY=

# 한국은행 ECOS (버핏지수 GDP)
ECOS_API_KEY=

# 알라딘 오픈API (경제·재테크 도서 베스트셀러 비중)
ALADIN_TTB_KEY=

# YouTube Data API (인기 급상승 동영상 중 경제 콘텐츠 비중)
YOUTUBE_API_KEY=

# 공공데이터포털 - 기상청 ASOS 일자료 (서울 맑은 날씨 지수)
KMA_API_KEY=

# GitHub 검색 API (트레이딩봇 저장소 생성 수) - 선택, 없으면 비인증으로 호출됨(rate limit만 낮아짐)
GITHUB_TOKEN=

# Anthropic (히어로 '오늘의 요약' 생성 - Claude Haiku). 없으면 요약만 건너뜀
ANTHROPIC_API_KEY=

# Telegram (카더라 리포트 - 채널 메시지 수집). my.telegram.org에서 발급 후
# scripts/generate_telegram_session.py로 세션 1회 생성. 세션은 절대 커밋 금지
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=

# 모니터링 채널 목록 구글시트 ID (카더라 리포트)
TELEGRAM_CHANNELS_SHEET_ID=

# Supabase
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
